<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Job Posted Successfully - Eksathi</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          sans-serif;
        background: #f5f7fa;
        line-height: 1.6;
      }

      .container {
        max-width: 600px;
        margin: 20px auto;
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      }

      .header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        text-align: center;
        padding: 40px 20px;
      }

      .logo {
        width: 80px;
        height: 80px;
        background: rgba(255, 255, 255, 0.15);
        border-radius: 20px;
        margin: 0 auto 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: bold;
        letter-spacing: -1px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        backdrop-filter: blur(10px);
      }

      .content {
        padding: 30px;
      }

      .success-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #4caf50 0%, #45a049 100%);
        border-radius: 50%;
        margin: 0 auto 25px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
      }

      .greeting {
        text-align: center;
        margin-bottom: 30px;
      }

      .success-box {
        background: linear-gradient(135deg, #4caf50 0%, #45a049 100%);
        color: white;
        border-radius: 12px;
        padding: 30px;
        margin: 25px 0;
        text-align: center;
      }

      .info-card {
        background: #f8f9ff;
        border-radius: 12px;
        padding: 25px;
        margin: 20px 0;
        border-left: 4px solid #667eea;
      }

      .info-card h4 {
        color: #667eea;
        margin-bottom: 15px;
      }

      .info-card p {
        color: #555;
        margin: 8px 0;
      }

      .posted-by-box {
        background: #e3f2fd;
        border-left: 4px solid #2196f3;
        padding: 20px;
        border-radius: 8px;
        margin: 20px 0;
      }

      .posted-by-box strong {
        color: #1976d2;
        display: block;
        margin-bottom: 10px;
        font-size: 16px;
      }

      .posted-by-box p {
        color: #555;
        margin: 0;
      }

      .cta-button {
        display: inline-block;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        text-decoration: none;
        padding: 15px 40px;
        border-radius: 25px;
        font-weight: 600;
        text-align: center;
        margin: 20px 0;
      }

      .footer {
        background: #2c3e50;
        color: white;
        text-align: center;
        padding: 30px 20px;
      }

      .social-links {
        margin: 20px 0;
      }

      .social-links a {
        display: inline-block;
        margin: 0 10px;
        color: white;
        text-decoration: none;
        padding: 10px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 8px;
      }

      /* Mobile Responsive */
      @media (max-width: 600px) {
        .container {
          margin: 10px;
          border-radius: 8px;
        }

        .header {
          padding: 30px 15px;
        }

        .content {
          padding: 20px 15px;
        }

        .success-box {
          padding: 20px;
        }

        .info-card {
          padding: 20px 15px;
        }

        .cta-button {
          display: block;
          width: 100%;
        }

        .footer {
          padding: 20px 15px;
        }

        .logo,
        .success-icon {
          width: 70px;
          height: 70px;
        }

        h1 {
          font-size: 24px;
        }

        h2 {
          font-size: 20px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <!-- Header -->
      <div class="header">
        <div class="logo">
          <img
            src="https://www.eksathi.com/logo192.png"
            alt="Eksathi Logo"
            style="max-width: 100%; height: auto"
          />
        </div>
        <h1>Job Posted Successfully! ✅</h1>
        <p>Your job posting is now live on Eksathi</p>
      </div>

      <!-- Main Content -->
      <div class="content">
        <!-- Success Icon -->
        <div class="success-icon">✓</div>

        <!-- Greeting -->
        <div class="greeting">
          <h2>Great News!</h2>
          <p style="color: #666; margin-top: 10px; font-size: 16px">
            Your job posting has been successfully published on Eksathi platform.
          </p>
        </div>

        <!-- Success Box -->
        <div class="success-box">
          <h3 style="margin-bottom: 15px">🎉 Job Posted Successfully</h3>
          <p style="font-size: 16px; opacity: 0.95">
            The job posting for <strong><%= instituteName %></strong> is now visible to all candidates on the Eksathi platform.
          </p>
        </div>

        <!-- Posted By Notice -->
        <div class="posted-by-box">
          <% if (role === 'institute') { %>
          <strong>🏫 Posted by Institute</strong>
          <p>
            This job has been posted directly by your institute. Qualified candidates can now view and apply for this position.
          </p>
          <% } else if (role === 'admin' || role === 'superadmin') { %>
          <strong>👨‍💼 Posted by Admin</strong>
          <p>
            This job has been posted by the Eksathi admin team on behalf of your institute. Qualified candidates can now view and apply for this position.
          </p>
          <% } %>
        </div>

        <!-- What's Next -->
        <div class="info-card">
          <h4>📋 What Happens Next?</h4>
          <p>✅ Your job posting is now live and visible to candidates</p>
          <p>✅ Candidates can search and apply for this position</p>
          <p>✅ You will receive notifications when candidates apply</p>
          <p>✅ You can manage applications through your dashboard</p>
        </div>

        <!-- CTA Button -->
        <div style="text-align: center; margin: 30px 0">
          <a href="https://www.eksathi.com/institute/jobs" class="cta-button">
            🔗 Manage Your Job Posting
          </a>
          <p style="color: #666; font-size: 14px; margin-top: 15px">
            Click above to see how your job posting appears to candidates
          </p>
        </div>

        <!-- Additional Info -->
        <div class="info-card" style="background: #fff3cd; border-left-color: #ffc107">
          <h4 style="color: #856404">💡 Pro Tip</h4>
          <p style="color: #856404">
            Share your job posting on social media to reach more qualified candidates and get faster responses!
          </p>
        </div>
      </div>

      <!-- Footer -->
      <div class="footer">
        <h3>Stay Connected</h3>
        <div class="social-links">
          <a href="https://www.facebook.com/ek.sathi.71/">Facebook</a>
          <a href="https://www.linkedin.com/in/eksathi/">LinkedIn</a>
          <a href="https://www.instagram.com/eksathi21/">Instagram</a>
        </div>

        <p style="margin: 20px 0; color: #ccc">
          Need help? Contact us at
          <a href="mailto:support@eksathi.com" style="color: #667eea"
            >support@eksathi.com</a
          >
        </p>

        <p style="font-size: 12px; opacity: 0.8">
          © <%= new Date().getFullYear() %> Eksathi. All rights reserved.<br />
          This email was sent to <%= email %>
        </p>
      </div>
    </div>
  </body>
</html>