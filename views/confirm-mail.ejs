<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Internal Notification - Candidate Response Received</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      background-color: #f4f4f4;
    "
  >
    <table
      role="presentation"
      cellspacing="0"
      cellpadding="0"
      border="0"
      width="100%"
      style="background-color: #f4f4f4"
    >
      <tr>
        <td align="center" style="padding: 30px 0">
          <table
            role="presentation"
            cellspacing="0"
            cellpadding="0"
            border="0"
            width="500"
            style="
              background-color: #ffffff;
              border-radius: 8px;
              box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
              max-width: 500px;
            "
          >
            <!-- Header -->
            <tr>
              <td
                style="
                  background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
                  padding: 20px;
                  text-align: center;
                  border-radius: 8px 8px 0 0;
                "
              >
                <h1
                  style="
                    color: #ffffff;
                    margin: 0;
                    font-size: 18px;
                    font-weight: 600;
                  "
                >
                  INTERNAL NOTIFICATION
                </h1>
                <p
                  style="
                    color: #ffffff;
                    margin: 5px 0 0 0;
                    font-size: 12px;
                    opacity: 0.9;
                  "
                >
                  HR Management System - <%= instituteName %>
                </p>
              </td>
            </tr>

            <!-- Main Content -->
            <tr>
              <td style="padding: 25px">
                <!-- Alert Icon -->
                <div style="text-align: center; margin-bottom: 15px">
                  <div
                    style="
                      display: inline-block;
                      width: 40px;
                      height: 40px;
                      background: #007bff;
                      border-radius: 50%;
                      position: relative;
                    "
                  >
                    <span
                      style="
                        color: white;
                        font-size: 20px;
                        position: absolute;
                        top: 50%;
                        left: 50%;
                        transform: translate(-50%, -50%);
                      "
                      >!</span
                    >
                  </div>
                </div>

                <h2
                  style="
                    color: #2c3e50;
                    text-align: center;
                    margin: 0 0 20px 0;
                    font-size: 16px;
                    font-weight: 600;
                  "
                >
                  Candidate Response Received
                </h2>

                <!-- Candidate Details -->
                <div
                  style="
                    background-color: #f8f9fa;
                    border: 1px solid #e9ecef;
                    padding: 15px;
                    margin: 15px 0;
                    border-radius: 6px;
                  "
                >
                  <h3
                    style="
                      color: #495057;
                      margin: 0 0 10px 0;
                      font-size: 14px;
                      font-weight: 600;
                    "
                  >
                    Candidate Information:
                  </h3>
                  <table style="width: 100%; font-size: 12px; color: #6c757d;">
                    <tr>
                      <td style="padding: 2px 0; width: 30%; font-weight: 500;">Name:</td>
                      <td style="padding: 2px 0;"><%= candidateName %></td>
                    </tr>
                    <tr>
                      <td style="padding: 2px 0; font-weight: 500;">Email:</td>
                      <td style="padding: 2px 0;"><%= candidateEmail %></td>
                    </tr>
                    <tr>
                      <td style="padding: 2px 0; font-weight: 500;">Phone:</td>
                      <td style="padding: 2px 0;"><%= candidatePhone %></td>
                    </tr>
                    <tr>
                      <td style="padding: 2px 0; font-weight: 500;">Position:</td>
                      <td style="padding: 2px 0;"><%= jobTitle %></td>
                    </tr>
                  </table>
                </div>

                <!-- Status Update -->
                <div
                  style="
                    background-color: #d4edda;
                    border: 1px solid #c3e6cb;
                    padding: 12px;
                    margin: 15px 0;
                    border-radius: 6px;
                  "
                >
                  <p style="color: #155724; margin: 0; font-size: 13px; font-weight: 500;">
                    ✓ Candidate has acknowledged the resume shortlisted notification
                  </p>
                  <p style="color: #155724; margin: 5px 0 0 0; font-size: 12px;">
                    Response received on: <%= new Date().toLocaleString() %>
                  </p>
                </div>

                <!-- Action Required -->
                <div
                  style="
                    background-color: #fff3cd;
                    border: 1px solid #ffeaa7;
                    padding: 12px;
                    margin: 15px 0;
                    border-radius: 6px;
                  "
                >
                  <p style="color: #856404; margin: 0; font-size: 13px; font-weight: 500;">
                    ACTION REQUIRED:
                  </p>
                  <p style="color: #856404; margin: 5px 0 0 0; font-size: 12px;">
                    Schedule interview within 2-3 business days
                  </p>
                </div>

                <!-- System Info -->
                <div style="text-align: center; margin-top: 20px; padding-top: 15px; border-top: 1px solid #e9ecef;">
                  <p style="color: #adb5bd; font-size: 10px; margin: 0 0 5px 0;">
                    System ID: RESP-<%= Date.now().toString().slice(-8) %>
                  </p>
                  <p style="color: #adb5bd; font-size: 10px; margin: 0;">
                    Generated: <%= new Date().toISOString() %>
                  </p>
                </div>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                style="
                  background-color: #f8f9fa;
                  padding: 10px;
                  text-align: center;
                  border-radius: 0 0 8px 8px;
                  border-top: 1px solid #e9ecef;
                "
              >
                <p
                  style="
                    color: #adb5bd;
                    font-size: 9px;
                    margin: 0;
                    line-height: 1.3;
                  "
                >
                  Automated HR Management System | <%= instituteName %> | Internal Use Only
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>