<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 0; background-color: #f4f4f4; }
    .container { max-width: 600px; margin: 20px auto; background: white; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
    .header { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; padding: 40px 20px; text-align: center; }
    .header h1 { margin: 0; font-size: 32px; }
    .content { padding: 40px 30px; line-height: 1.6; color: #333; }
    .announcement-icon { font-size: 64px; text-align: center; margin: 20px 0; }
    .announcement-box { background: linear-gradient(135deg, #fff5f5 0%, #ffe5e5 100%); border-left: 4px solid #f5576c; padding: 20px; border-radius: 5px; margin: 20px 0; }
    .button { display: inline-block; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; padding: 15px 40px; text-decoration: none; border-radius: 25px; margin: 20px 0; font-weight: bold; }
    .date-badge { display: inline-block; background: #f5576c; color: white; padding: 5px 15px; border-radius: 15px; font-size: 12px; margin-bottom: 10px; }
    .footer { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 40px 20px; text-align: center; margin-top: 40px; border-radius: 0 0 10px 10px; }
    .sparkle-text { font-size: 24px; margin-bottom: 20px; }
    .social-links { margin: 20px 0; }
    .social-links a { color: white; text-decoration: none; padding: 10px 20px; background: rgba(255,255,255,0.2); border-radius: 25px; margin: 5px; display: inline-block; }
    .diwali-decoration { font-size: 32px; margin: 20px 0; }
    .footer-text { margin: 15px 0; font-size: 14px; }
    .footer-text a { color: #ffd700; text-decoration: none; font-weight: bold; }
    .footer-copyright { margin: 15px 0; font-size: 12px; opacity: 0.9; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>📢 <%= subject %></h1>
    </div>
    <div class="content">
      <div class="announcement-icon">📣</div>
      <h2 style="color: #f5576c;">
        <% if (role === 'student') { %>
          Dear <%= username %>,
        <% } else if (role === 'teacher') { %>
          Dear Esteemed <%= username %>,
        <% } else if (role === 'professional') { %>
          Dear <%= username %>,
        <% } else if (role === 'institute') { %>
          Dear <%= username %>,
        <% } else { %>
          Dear <%= username %>,
        <% } %>
      </h2>
      
      <div class="date-badge">📅 <%= new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></div>
      
      <div class="announcement-box">
        <p><%= message %></p>
      </div>
      
      <p><strong>Important Points to Remember:</strong></p>
      <ul style="color: #555;">
        <li>Please read this announcement thoroughly</li>
        <li>Mark important dates in your calendar</li>
        <li>Contact us if you have any questions</li>
        <li>Share this information with relevant parties if necessary</li>
      </ul>
      
      <center>
        <a href="https://eksathi.com/announcements" class="button">View Full Details →</a>
      </center>
      
      <p style="margin-top: 30px;">Thank you for your attention,<br><strong>The Eksathi Team</strong></p>
    </div>
    
  
    <%- include('footer', { email: email }) %>

  </div>
</body>
</html>