<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 0; background-color: #f4f4f4; }
    .container { max-width: 600px; margin: 20px auto; background: white; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
    .header { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; padding: 40px 20px; text-align: center; }
    .header h1 { margin: 0; font-size: 32px; }
    .content { padding: 40px 30px; line-height: 1.6; color: #333; }
    .update-icon { font-size: 64px; text-align: center; margin: 20px 0; }
    .update-box { background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%); padding: 20px; border-radius: 10px; margin: 20px 0; border-left: 4px solid #2196f3; }
    .feature-badge { display: inline-block; background: #4caf50; color: white; padding: 5px 12px; border-radius: 12px; font-size: 11px; margin: 5px 5px 5px 0; }
    .button { display: inline-block; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; padding: 15px 40px; text-decoration: none; border-radius: 25px; margin: 20px 0; font-weight: bold; }
    .footer { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 40px 20px; text-align: center; margin-top: 40px; border-radius: 0 0 10px 10px; }
    .sparkle-text { font-size: 24px; margin-bottom: 20px; }
    .social-links { margin: 20px 0; }
    .social-links a { color: white; text-decoration: none; padding: 10px 20px; background: rgba(255,255,255,0.2); border-radius: 25px; margin: 5px; display: inline-block; }
    .diwali-decoration { font-size: 32px; margin: 20px 0; }
    .footer-text { margin: 15px 0; font-size: 14px; }
    .footer-text a { color: #ffd700; text-decoration: none; font-weight: bold; }
    .footer-copyright { margin: 15px 0; font-size: 12px; opacity: 0.9; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>🚀 <%= subject %></h1>
    </div>
    <div class="content">
      <div class="update-icon">🔄</div>
      <h2 style="color: #2196f3;">
        <% if (role === 'student') { %>
          Dear <%= username %>,
        <% } else if (role === 'teacher') { %>
          Dear Esteemed <%= username %>,
        <% } else if (role === 'professional') { %>
          Dear <%= username %>,
        <% } else if (role === 'institute') { %>
          Dear <%= username %>,
        <% } else { %>
          Dear <%= username %>,
        <% } %>
      </h2>
      
      <p>We're excited to share the latest updates and improvements we've made to enhance your experience on Eksathi!</p>
      
      <div class="update-box">
        <p><%= message %></p>
      </div>

      <div style="background: #f5f5f5; padding: 20px; border-radius: 10px; margin: 20px 0;">
        <h3 style="color: #2196f3; margin-top: 0;">✨ What's New:</h3>
        <div style="margin: 10px 0;">
          <span class="feature-badge">NEW</span> <strong>Enhanced Performance</strong><br>
          <span style="color: #666; font-size: 14px;">Faster loading times and smoother navigation</span>
        </div>
        <div style="margin: 10px 0;">
          <span class="feature-badge">IMPROVED</span> <strong>User Interface</strong><br>
          <span style="color: #666; font-size: 14px;">More intuitive design and better accessibility</span>
        </div>
        <div style="margin: 10px 0;">
          <span class="feature-badge">FIXED</span> <strong>Bug Fixes</strong><br>
          <span style="color: #666; font-size: 14px;">Resolved reported issues for better stability</span>
        </div>
      </div>

      <center>
        <a href="https://eksathi.com/updates" class="button">Explore Updates →</a>
      </center>

      <p style="margin-top: 30px;">Keep exploring and enjoying!<br><strong>The Eksathi Team</strong></p>
    </div>
    
    <%- include('footer', { email: email }) %>
  </div>
</body>
</html>`