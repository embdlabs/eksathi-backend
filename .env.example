# Server
PORT=5000
NODE_ENV=development

# Database (used by model/db.js — falls back to config/config.json if unset)
DBHOST=66.116.224.80
DBUSER=eksathi
DBPASS=your-db-password
DBNAME=eksathi-production

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_SECRET_INSTITUTE=your-institute-jwt-secret-here

# Google OAuth (optional — server starts without these)
GOOGLE_ID=
GOOGLE_SECRET=

# OpenAI (optional — chat AI falls back without this)
OPENAI_API_KEY=

# Frontend URL (password reset emails)
FRONTEND_URL=http://localhost:3000

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

